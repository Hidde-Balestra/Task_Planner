<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Task Planner"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF757575"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Vandaag"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF2196F3"
            android:gravity="center_vertical"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFE0E0E0"
        android:layout_marginBottom="4dp" />

    <!-- Task row 0 -->
    <LinearLayout
        android:id="@+id/task_row_0"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/task_check_0"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:id="@+id/task_title_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task row 1 -->
    <LinearLayout
        android:id="@+id/task_row_1"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/task_check_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:id="@+id/task_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task row 2 -->
    <LinearLayout
        android:id="@+id/task_row_2"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/task_check_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:id="@+id/task_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task row 3 -->
    <LinearLayout
        android:id="@+id/task_row_3"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/task_check_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:id="@+id/task_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task row 4 -->
    <LinearLayout
        android:id="@+id/task_row_4"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">
        <ImageView
            android:id="@+id/task_check_4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/widget_check_off" />
        <TextView
            android:id="@+id/task_title_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#FF212121"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Empty state: fills remaining space when no tasks -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Geen taken vandaag"
        android:textSize="13sp"
        android:textColor="#FF9E9E9E"
        android:visibility="visible" />

    <!-- "+N meer taken" shown when > 5 tasks -->
    <TextView
        android:id="@+id/widget_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="10sp"
        android:textColor="#FF9E9E9E"
        android:visibility="gone" />

    <!-- Open app link -->
    <TextView
        android:id="@+id/widget_open_app"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open app →"
        android:textSize="10sp"
        android:textColor="#FF2196F3"
        android:gravity="end"
        android:paddingTop="2dp" />
</LinearLayout>
